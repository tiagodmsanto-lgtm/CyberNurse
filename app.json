{
  "expo": {
    "name": "Cyber Nurse",
    "slug": "CyberNurse",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cybernurse",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cybernurse.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E53935",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.InkluDevs.CyberNurse",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "CAMERA",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "POST_NOTIFICATIONS",
        "READ_CALENDAR",
        "WRITE_CALENDAR",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-firebase/app",
      "@react-native-firebase/crashlytics",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#E53935"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Cyber Nurse precisa da câmera para verificar que você tomou sua medicação."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#E53935",
          "sounds": []
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Cyber Nurse precisa acessar seu calendário para sincronizar lembretes de medicamentos."
        }
      ],
      "@react-native-firebase/analytics",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "appName": "Cyber Nurse",
      "appVersion": "1.0.0"
    }
  }
}
